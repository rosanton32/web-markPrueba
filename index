<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Unit 20 Iberia | Marketing & Consultoría</title>
<link href="https://googleapis.com" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg-primary:    #0C0C0C;
  --bg-secondary:  #141414;
  --bg-card:       #181818;
  --surface-1:     #1E1E1E;
  --surface-border:#2A2A2A;
  --text-primary:  #F0F0F0;
  --text-muted:    rgba(240,240,240,0.6);
  --text-faint:    rgba(240,240,240,0.25);
  --neon:          #00F0FF; 
  --neon-dim:      rgba(0,240,255,0.1);
  --neon-glow:     0 0 20px rgba(0,240,255,0.3);
  --font-d: 'Syne', sans-serif;
  --font-b: 'DM Sans', sans-serif;
  --radius: 4px;
}

html { scroll-behavior: smooth; }
body { background: var(--bg-primary); color: var(--text-primary); font-family: var(--font-b); overflow-x: hidden; -webkit-font-smoothing: antialiased; }

nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.2rem 5%;
  background: rgba(12,12,12,0.85);
  backdrop-filter: blur(15px);
  border-bottom: 1px solid var(--surface-border);
}
.nav-logo { 
  font-family: var(--font-d); font-weight: 800; font-size: 1.1rem; 
  letter-spacing: -0.02em; /* Menos estirado */
  text-transform: uppercase; 
}
.nav-logo em { color: var(--neon); font-style: normal; }

.nav-links { display: flex; gap: 2.5rem; list-style: none; align-items: center; }
.nav-links a { font-size: 0.85rem; font-weight: 500; color: var(--text-muted); text-decoration: none; transition: 0.3s; }
.nav-links a:hover { color: var(--text-primary); }

.btn-neon {
  background: var(--neon); color: #000 !important;
  padding: 0.6rem 1.4rem; border-radius: var(--radius);
  font-family: var(--font-d); font-weight: 700 !important;
  font-size: 0.8rem !important; letter-spacing: 0.02em;
  transition: 0.3s;
}
.btn-neon:hover { box-shadow: var(--neon-glow); transform: scale(1.03); }

.hero {
  min-height: 100vh;
  display: flex; flex-direction: column; justify-content: center;
  padding: 0 5%;
  position: relative; overflow: hidden;
}
.hero-glow {
  position: absolute; inset: 0; z-index: -1;
  background: radial-gradient(circle at 80% 20%, rgba(0,240,255,0.08), transparent 50%);
}
.hero-grid {
  position: absolute; inset: 0; z-index: -2;
  background-image: linear-gradient(var(--surface-border) 1px, transparent 1px), linear-gradient(90deg, var(--surface-border) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 20%, transparent 90%);
  opacity: 0.4;
}

.hero-badge {
  display: inline-flex; align-items: center; gap: 0.7rem;
  font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--neon);
  border: 1px solid rgba(0,240,255,0.25); padding: 0.5rem 1.2rem;
  border-radius: 2px; width: fit-content; margin-bottom: 2rem;
}

.hero h1 {
  font-family: var(--font-d);
  font-size: clamp(3rem, 7.5vw, 6.5rem);
  font-weight: 800; line-height: 1; 
  letter-spacing: -0.05em; /* Cambio clave: Letras más juntas para evitar efecto estirado */
  max-width: 950px; margin-bottom: 2.5rem;
}
.hero h1 .hl { color: var(--neon); }

.hero-desc { font-size: 1.1rem; line-height: 1.6; color: var(--text-muted); max-width: 550px; margin-bottom: 3rem; }

.btn-primary {
  background: var(--neon); color: #000;
  padding: 1.1rem 2.4rem; border-radius: var(--radius);
  font-family: var(--font-d); font-size: 0.9rem; font-weight: 700;
  text-decoration: none; text-transform: uppercase; display: inline-block;
  transition: 0.3s;
}
.btn-primary:hover { box-shadow: var(--neon-glow); transform: translateY(-3px); }

.ticker { overflow: hidden; padding: 1.2rem 0; background: var(--bg-secondary); border-y: 1px solid var(--surface-border); }
.ticker-track { display: flex; width: max-content; animation: tick 25s linear infinite; }
.ticker-item { 
    display: flex; align-items: center; gap: 1rem; padding: 0 3rem; 
    font-size: 0.8rem; font-family: var(--font-d); font-weight: 700; 
    letter-spacing: 0.05em; text-transform: uppercase; color: var(--text-faint); 
}
@keyframes tick { from{transform:translateX(0)} to{transform:translateX(-50%)} }

section { padding: 8rem 5%; }
.s-label { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.25em; text-transform: uppercase; color: var(--neon); margin-bottom: 1rem; display: block; }
.s-title { font-family: var(--font-d); font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; letter-spacing: -0.04em; margin-bottom: 3.5rem; }

.svc-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
.svc-card { 
    background: var(--bg-card); padding: 3rem 2rem; border: 1px solid var(--surface-border); 
    transition: 0.4s; position: relative; 
}
.svc-card:hover { border-color: var(--neon); background: var(--surface-1); transform: translateY(-5px); }
.svc-num { color: var(--neon); font-family: var(--font-d); font-weight: 800; font-size: 0.9rem; margin-bottom: 1.5rem; display: block; }
.svc-name { font-family: var(--font-d); font-size: 1.4rem; font-weight: 700; margin-bottom: 1rem; letter-spacing: -0.02em; }
.svc-desc { color: var(--text-muted); font-size: 0.95rem; line-height: 1.6; }

#stats { padding: 5rem 5%; border-top: 1px solid var(--surface-border); }
.stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; }
.stat-n { font-family: var(--font-d); font-size: 3.5rem; font-weight: 800; color: var(--neon); letter-spacing: -0.05em; margin-bottom: 0.5rem; }
.stat-l { font-size: 0.8rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); }

@media (max-width: 768px) {
  .hero h1 { font-size: 3.2rem; }
  .nav-links { display: none; }
}
</style>
</head>
<body>

<nav>
  <div class="nav-logo">UNIT <em>20</em> IBERIA</div>
  <ul class="nav-links">
    <li><a href="#servicios">Servicios</a></li>
    <li><a href="#agencia">Agencia</a></li>
    <li><a href="#contacto">Contacto</a></li>
    <li><a href="#contacto" class="btn-neon">PROYECTO</a></li>
  </ul>
</nav>

<div class="hero">
  <div class="hero-glow"></div>
  <div class="hero-grid"></div>
  <div class="hero-badge">Consultoría & Marketing Digital</div>
  <h1>Expertos en <span class="hl">Escalar</span> Marcas de Alto Nivel.</h1>
  <p class="hero-desc">En Unit 20 Iberia diseñamos estrategias de precisión para empresas que buscan liderar su sector mediante innovación y datos.</p>
  <div class="hero-ctas">
    <a href="#servicios" class="btn-primary">Nuestros Servicios</a>
  </div>
</div>

<div class="ticker">
  <div class="ticker-track">
    <div class="ticker-item">Unit 20 Iberia</div><div class="ticker-item">•</div>
    <div class="ticker-item">Marketing Digital</div><div class="ticker-item">•</div>
    <div class="ticker-item">Consultoría</div><div class="ticker-item">•</div>
    <div class="ticker-item">Publicidad</div><div class="ticker-item">•</div>
    <div class="ticker-item">Branding</div><div class="ticker-item">•</div>
    <div class="ticker-item">Unit 20 Iberia</div><div class="ticker-item">•</div>
    <div class="ticker-item">Marketing Digital</div><div class="ticker-item">•</div>
  </div>
</div>

<section id="servicios">
  <span class="s-label">Capacidades</span>
  <h2 class="s-title">Soluciones que impulsan tu negocio.</h2>
  <div class="svc-grid">
    <div class="svc-card">
      <span class="svc-num">01 / ESTRATEGIA</span>
      <h3 class="svc-name">Consultoría 360</h3>
      <p class="svc-desc">Optimización de procesos comerciales y detección de nuevos canales de adquisición.</p>
    </div>
    <div class="svc-card">
      <span class="svc-num">02 / PUBLICIDAD</span>
      <h3 class="svc-name">Paid Media</h3>
      <p class="svc-desc">Gestión avanzada de presupuestos publicitarios enfocada en el retorno directo (ROI).</p>
    </div>
    <div class="svc-card">
      <span class="svc-num">03 / DISEÑO</span>
      <h3 class="svc-name">Digital Branding</h3>
      <p class="svc-desc">Identidades visuales sólidas y assets digitales que posicionan tu marca por encima del resto.</p>
    </div>
  </div>
</section>

<div id="stats">
  <div class="stats-row">
    <div class="stat"><div class="stat-n">20+</div><div class="stat-l">Casos de Éxito</div></div>
    <div class="stat"><div class="stat-n">100%</div><div class="stat-l">Foco en Datos</div></div>
    <div class="stat"><div class="stat-n">24/7</div><div class="stat-l">Soporte Estratégico</div></div>
    <div class="stat"><div class="stat-n">x3</div><div class="stat-l">Media de Escalado</div></div>
  </div>
</div>

</body>
</html>
